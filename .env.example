# Copy to .env and replace every placeholder before exposing the service.
REPROIT_API_KEY=replace-with-at-least-32-random-bytes
REPROIT_PUBLIC_URL=https://bugs.example.com

# Optional bootstrap (remove after the first successful start).
REPROIT_BOOTSTRAP_EMAIL=admin@example.com
REPROIT_BOOTSTRAP_PASSWORD=replace-with-a-long-random-password
REPROIT_BOOTSTRAP_PROJECT=Default

# Neon Local overlay (compose.neon.yml): prod-parity Postgres via an ephemeral
# Neon branch. NEON_BRANCH_ID pins an existing branch; NEON_DELETE_BRANCH=false
# keeps the ephemeral one. NEON_DATABASE is the database in your Neon project.
# NEON_API_KEY=
# NEON_PROJECT_ID=
# NEON_BRANCH_ID=
# NEON_DELETE_BRANCH=true
# NEON_DATABASE=neondb

# Optional S3-compatible evidence storage (requires the `r2` build feature).
# R2_ENDPOINT=https://s3.example.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=reproit-evidence
